<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.1/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-4bw+/aepP/YC94hEpVNVgiZdgIC5+VKNBQNGCHeKRQN+PtmoHDEXuppvnDJzQIu9"
          crossorigin="anonymous">
    <link rel="stylesheet" href="../css/main.css"/>
    <link rel="stylesheet" href="/css/style.css">
    <title><%= title %></title>
</head>
<body>
<%- include('./includes/navbar') %>

<% if (products.length === 0) { %>

    <div class="empty-state">
        <div class="empty-icon">🛍️</div>
        <h2>No Products Found</h2>
        <p>We're stocking up! Check back soon for amazing deals.</p>
        <a href="/" class="btn-home">Go Back Home</a>
    </div>

<% } else { %>


    <div class="card-grid">
        <% products.forEach(product => { %>
            <%- include('partials/card', { product }) %>
        <% }) %>
    </div>

<% } %>

</body>
</html>