<!DOCTYPE html>
<html lang="en">
   <head>
       <meta charset="UTF-8">
       <meta http-equiv="X-UA-Compatible" content="IE=edge">
       <meta name="viewport" content="width=device-width, initial-scale=1.0">
       <title>New Product</title>
       <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.1/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-4bw+/aepP/YC94hEpVNVgiZdgIC5+VKNBQNGCHeKRQN+PtmoHDEXuppvnDJzQIu9" crossorigin="anonymous">
       <link rel="stylesheet" href="../css/main.css"/>
       <link rel="stylesheet" href="../css/admin.css"/>
   </head>
   <body>
        <%- include('./includes/navbar.ejs') %>
       <div class="container mt-4 form-container">
           <form class="w-25" action="/new_product" method="post">
               <div class="form-control m-3 p-2">
                   <div class="mt-2 mb-3">
                       <label class="form-label fs-4">Title</label>
                       <input type="text" name="title" class="form-control">
                   </div>
                   <div class="my-3">
                       <label class="form-label fs-4">Select Image</label>
                       <input type="file" name="img" class="form-control">
                   </div>
               </div>
  
               <button class="btn btn-primary fs-4 m-3 px-3 w-100" type="submit">Add Product</button>
           </form>
       </div>
   </body>
</html>


