<!DOCTYPE html>
<html lang="en">
    <head>
        <title>Document</title>
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.1/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-4bw+/aepP/YC94hEpVNVgiZdgIC5+VKNBQNGCHeKRQN+PtmoHDEXuppvnDJzQIu9" crossorigin="anonymous">
        <link rel="stylesheet" href="../css/main.css"/>
    </head>
    <body>
        <%- include('./includes/navbar.ejs') %>

        <div class="card-container pt-3">
            <% if(products.length>0){ %>
                <% for(let product of products){ %>
                    <div class="card m-3 custom-card">
                        <img
                            src = <%="/assets/" + product.img ? product.img :['apples.jpg','bananas.jpg','oranges.jpg','pineapple.jpg','strawberry.jpg'][Math.floor(Math.random()*5)] %>
                            alt= <%= product.img ? product.img : ['apples.jpg','bananas.jpg','oranges.jpg','pineapple.jpg','strawberry.jpg'][Math.floor(Math.random()*5)] %>
                            class="card-img-top card_image"
                        />
                        <div class="card-body">
                            <h3 class="card-title m-1"> <%= product.title%> </h3>
                            <button class="btn btn-warning w-100 mt-3"> Add to Cart </button>
                        </div>
                    </div>
                <% } %>
            <% } else { %>
                <div>
                    <h1> No Products Available </h1>
                    <a href="/new_product" class="btn btn-outline-dark fs-4 my-3"> Add Products </a>
                </div>
            <% } %>
        </div>
    </body>
</html>


